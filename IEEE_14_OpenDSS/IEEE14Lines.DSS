/*
Network data extracted from MatPower Version 7.1.
All per unit values converted to actual values with the formula Z_pu = Z_Ohms/Z_base
where Z_base = (KV_LL)^2/MVA_base
MVA_base = 100MVA
Bus Voltage KV_LL = 1kV (Since VBus Voltages are not mentioned in Common Data Format, Assumed KV_LL = 1kV based on ETAP IEEE14Bus Model)

Susceptance B (in microS) = (B_pu x 10^6)/Z_base

This version uses LineCode objects with positive-sequence equivalents matching the
original per-line R1/X1/B1 data (1 kV base). C1 [nF] is computed from B1 [µS] via
    C1 = B1 * 1000 / (2*pi*60).
*/

Set DefaultBaseFrequency=60

! 1-2 (3-phase LineCode using full matrices; diag only, no mutuals)
New LineCode.LC_1_2 nphases=3 BaseFreq=60 Units=None
~ Rmatrix=[ 0.0001938 | 0 0.0001938 | 0 0 0.0001938 ]
~ Xmatrix=[ 0.0005917 | 0 0.0005917 | 0 0 0.0005917 ]
~ Cmatrix=[ 14005634.99208679 | 0 14005634.99208679 | 0 0 14005634.99208679 ]
New Line.1-2 phases=3 Bus1=B1 Bus2=B2 LineCode=LC_1_2 Length=1

